{
  "name": "whiteboard-brainstorm",
  "version": "1.0.0-rc.1",
  "description": "Bidirectional whiteboard brainstorming on an Excalidraw canvas with Claude.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "wbb": "bin/wbb.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:e2e": "playwright test tests/e2e",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "chokidar": "3.6.0",
    "express": "4.19.2"
  },
  "devDependencies": {
    "@playwright/test": "1.45.0",
    "playwright": "^1.45.0"
  }
}
