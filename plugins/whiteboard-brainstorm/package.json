{
  "name": "whiteboard-brainstorm",
  "version": "1.0.0-rc.6",
  "description": "Bidirectional whiteboard brainstorming on an Excalidraw canvas for Claude Code and Codex. Draw, tag, and ping — the assistant responds with stickies, mind-nodes, annotations, and panels on the same board.",
  "keywords": [
    "claude-code",
    "claude",
    "codex",
    "ai",
    "brainstorming",
    "whiteboard",
    "excalidraw",
    "canvas",
    "mindmap",
    "skill",
    "plugin"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "wbb": "bin/wbb.js"
  },
  "files": [
    ".claude-plugin/",
    ".agents/",
    "AGENTS.md",
    "bin/",
    "lib/",
    "plugins/whiteboard-brainstorm/",
    "server/",
    "skills/",
    "scripts/",
    "plugin.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:e2e": "playwright test tests/e2e",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "chokidar": "3.6.0",
    "express": "4.19.2"
  },
  "devDependencies": {
    "@playwright/test": "1.45.0",
    "playwright": "^1.45.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khpind-personal/whiteboard-brainstorm.git"
  },
  "bugs": {
    "url": "https://github.com/khpind-personal/whiteboard-brainstorm/issues"
  },
  "homepage": "https://github.com/khpind-personal/whiteboard-brainstorm#readme"
}
